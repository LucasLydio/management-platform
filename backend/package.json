{
  "name": "management-task-backend",
  "version": "0.0.1",
  "private": true,
  "description": "Backend API for Management Tasks with Node.js, TypeScript, Prisma, Redis cache, Socket.IO, and clean layered architecture.",
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "schema": "src/infra/database/schema.prisma",
    "seed": "tsx src/infra/database/seed.ts"
  },
  "main": "dist/src/main.js",
  "types": "dist/src/main.d.ts",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/main.ts",
    "start": "node dist/src/main.js",
    "start:prod": "node dist/src/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "check": "npm run prisma:generate && npm run typecheck && npm test",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest --runInBand src/tests/unit",
    "test:integration": "jest --runInBand src/tests/integration",
    "test:e2e": "jest --runInBand src/tests/e2e",
    "prisma:format": "prisma format --schema src/infra/database/schema.prisma",
    "prisma:generate": "prisma generate --schema src/infra/database/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema src/infra/database/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema src/infra/database/schema.prisma",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --schema src/infra/database/schema.prisma",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "docker:up": "docker compose -f ../docker-compose.yml up --build backend postgres redis",
    "docker:down": "docker compose -f ../docker-compose.yml down",
    "docker:logs": "docker compose -f ../docker-compose.yml logs -f backend",
    "lint": "npm run typecheck",
    "lint:check": "npm run typecheck"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^4.7.1",
    "socket.io": "^4.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
